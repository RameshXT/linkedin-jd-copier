{
  "manifest_version": 3,
  "name": "LinkedIn Job Description Copier",
  "version": "1.0.0",
  "description": "Add a one-click button to easily copy job descriptions on LinkedIn.",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}